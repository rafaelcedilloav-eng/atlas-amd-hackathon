# ATLAS — Variables de entorno
# Copia este archivo a .env y completa tus valores reales

# vLLM (AMD MI300X — DeepSeek-R1)
VLLM_BASE_URL=http://YOUR_SERVER_IP:8000/v1
VLLM_MODEL=deepseek-ai/DeepSeek-R1-Distill-Qwen-32B
VLLM_TIMEOUT=120
VLLM_MAX_TOKENS=4096
VLLM_TEMPERATURE=0.1
VLLM_API_KEY=not-needed

# Supabase
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
# SERVICE KEY (requerida para escritura con RLS activo):
# Obtenla en: supabase.com/dashboard/project/<id>/settings/api → "service_role"
SUPABASE_SERVICE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY
SUPABASE_REST_API=https://YOUR_PROJECT_ID.supabase.co/rest/v1/

# Ollama (local fallback — opcional)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_VISION_MODEL=llava:7b
OLLAMA_EXPLAINER_MODEL=llama2:7b
OLLAMA_FALLBACK_MODEL=llama2:7b
OLLAMA_VALIDATOR_MODEL=qwen3.5:4b

# Logging
LOG_LEVEL=INFO
DEBUG=False

# Seguridad API
# Genera con: python -c "import secrets; print(secrets.token_hex(32))"
ATLAS_API_KEY=tu-api-key-segura-aqui
ATLAS_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
ATLAS_DOCS_DIR=test_documents

# Binarios de sistema (Windows — ajustar paths según instalación)
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
POPPLER_PATH=C:\Users\YOUR_USER\poppler-24.08.0\Library\bin
